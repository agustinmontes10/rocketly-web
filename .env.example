# Contacto público de Rocketly (usado en todos los CTAs de WhatsApp y el email).
# Copiá este archivo a .env.local y completá los valores reales antes de publicar.

# Número de WhatsApp Business con código de país, sin "+" ni espacios.
# Ej. Argentina: 5491122334455
NEXT_PUBLIC_WHATSAPP_NUMBER=549XXXXXXXXXX

# Email público de contacto.
NEXT_PUBLIC_CONTACT_EMAIL=contact.rocketly@gmail.com
